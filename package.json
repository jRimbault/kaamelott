{
  "name": "kaamelott-soundboard",
  "version": "1.0.0",
  "description": "Quelques-unes des meilleures répliques sonores de Kaamelott. C'était ça ou chante Sloubi.",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:index && npm run typecheck && vite build",
    "build:index": "tsx bin/build-index.ts",
    "sync:upstream": "tsx bin/sync-upstream.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint --ext ts src",
    "test": "echo no tests yet"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jRimbault/kaamelott.git"
  },
  "author": "Antoine @2ec0b4",
  "contributors": [
    "Jacques Rimbault <jacques.rimbault@gmail.com>"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jRimbault/kaamelott/issues"
  },
  "homepage": "https://github.com/jRimbault/kaamelott#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^2.34.0",
    "@typescript-eslint/parser": "^2.34.0",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jsdoc": "^18.11.0",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-prettier": "^3.3.1",
    "prettier": "^1.19.1",
    "tsx": "^4.19.0",
    "typescript": "^3.9.7",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^2.2.0"
  }
}
